{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "Customer table reservation",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "guests": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "guests", "date", "status"]
    },
    "Table": {
      "title": "Table",
      "description": "Restaurant table information",
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "capacity": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["number", "capacity", "isActive"]
    },
    "Order": {
      "title": "Order",
      "description": "Restaurant order",
      "type": "object",
      "properties": {
        "tableId": { "type": "string" },
        "tableNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "paidAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tableId", "items", "totalAmount", "status", "createdAt"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "Menu item details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Antipasti", "Primi", "Secondi", "Dolci", "Bevande"] },
        "isActive": { "type": "boolean" },
        "image": { "type": "string" }
      },
      "required": ["name", "price", "category", "isActive"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Authorized staff member",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "addedAt"]
    }
  },
  "firestore": {
    "reservations": {
      "schema": "Reservation",
      "description": "Customer reservations"
    },
    "staff": {
      "schema": "Staff",
      "description": "Authorized restaurant staff"
    },
    "tables": {
      "schema": "Table",
      "description": "Restaurant tables"
    },
    "orders": {
      "schema": "Order",
      "description": "Orders taken at tables"
    },
    "menuItems": {
      "schema": "MenuItem",
      "description": "Menu items"
    }
  }
}
